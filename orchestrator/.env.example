# Copy to .env and fill in. Never commit the real .env (see .gitignore).
# All settings use the TC_ prefix (see tc_growth/config.py).

# --- WordPress connector ---
TC_WP_BASE_URL=https://tossacycling.com
TC_WP_USER=tc-agent
TC_WP_APP_PASSWORD=
TC_WP_SIGNING_KEY=

# --- Google ---
TC_GSC_SITE_URL=sc-domain:tossacycling.com
TC_GA4_PROPERTY_ID=
TC_GOOGLE_ADS_CUSTOMER_ID=
TC_PAGESPEED_API_KEY=

# --- Meta ---
TC_META_AD_ACCOUNT_ID=act_
# TC_META_ACCESS_TOKEN is read from the environment directly, not via Settings.
TC_META_ACCESS_TOKEN=

# --- AI runtime (only used by runtime/) ---
TC_AI_PROVIDER=anthropic
TC_AI_MODEL=claude-opus-4-8
TC_AI_MODEL_CHEAP=claude-haiku-4-5
ANTHROPIC_API_KEY=

# --- Reporting ---
TC_REPORT_CHANNEL=email
TC_REPORT_RECIPIENT=lukaszkomar@gmail.com
TC_REPORT_SENDER=info@tossacycling.com
# SMTP (if TC_REPORT_CHANNEL=email). Unset = prints to stdout, never fails a run.
#
# RECOMMENDED: authenticated submission via IONOS — the provider you already own, no new
# dependency. IONOS blocks port 25 (direct MTA relay), NOT port 587 (authenticated submission),
# so sending from an IONOS mailbox over 587/STARTTLS works and inherits IONOS's SPF/DKIM so the
# mail lands in Gmail, not spam. Send AS the IONOS mailbox (From aligned to the sending domain).
#   TC_SMTP_HOST=smtp.ionos.com        # or smtp.ionos.co.uk / .es per your account region
#   TC_SMTP_USER=<your full IONOS mailbox address>
#   TC_SMTP_PASSWORD=<that mailbox's password>
#   TC_REPORT_SENDER=<the same IONOS mailbox address>   # keep From on the IONOS/owned domain
#
# FALLBACK ONLY if you have no IONOS mailbox / deliverability disappoints: a transactional relay
# (Brevo/Postmark/etc.) with a DKIM-verified sender. Overkill for one internal email/week, but the
# same TC_SMTP_* fields drive it — swap host/user/pass. Do NOT run your own Postfix MTA on the VPS
# for this: a fresh VPS IP has no sending reputation and Gmail will junk it.
# Confirmed IONOS values for this deployment (from the mailbox's SMTP settings); password is set
# only in the live .env on the VPS, never committed:
TC_SMTP_HOST=smtp.ionos.es
TC_SMTP_PORT=587
TC_SMTP_USER=info@tossacycling.com
TC_SMTP_PASSWORD=
TC_SMTP_STARTTLS=true
# Telegram (if TC_REPORT_CHANNEL=telegram):
TC_TELEGRAM_BOT_TOKEN=
TC_TELEGRAM_CHAT_ID=
