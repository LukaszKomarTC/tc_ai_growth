# Copy to .env and fill in. Never commit the real .env (see .gitignore).
# All settings use the TC_ prefix (see tc_growth/config.py).

# --- WordPress connector ---
TC_WP_BASE_URL=https://tossacycling.com
TC_WP_USER=tc-agent
TC_WP_APP_PASSWORD=
TC_WP_SIGNING_KEY=

# --- Google ---
TC_GSC_SITE_URL=sc-domain:tossacycling.com
TC_GA4_PROPERTY_ID=
TC_GOOGLE_ADS_CUSTOMER_ID=
TC_PAGESPEED_API_KEY=

# --- Meta ---
TC_META_AD_ACCOUNT_ID=act_
# TC_META_ACCESS_TOKEN is read from the environment directly, not via Settings.
TC_META_ACCESS_TOKEN=

# --- AI runtime (only used by runtime/) ---
TC_AI_PROVIDER=anthropic
TC_AI_MODEL=claude-opus-4-8
TC_AI_MODEL_CHEAP=claude-haiku-4-5
ANTHROPIC_API_KEY=

# --- Reporting ---
TC_REPORT_CHANNEL=email
TC_REPORT_RECIPIENT=lukaszkomar@gmail.com
TC_REPORT_SENDER=
# SMTP (if TC_REPORT_CHANNEL=email). Unset = prints to stdout, never fails a run.
# Brevo (recommended — IONOS blocks outbound port 25; Brevo uses 587/STARTTLS):
#   TC_SMTP_HOST=smtp-relay.brevo.com
#   TC_SMTP_USER=<your Brevo SMTP login, e.g. 9xxxxx@smtp-brevo.com>  (NOT your account email)
#   TC_SMTP_PASSWORD=<Brevo SMTP key>  (Brevo -> SMTP & API -> SMTP; NOT your login password)
#   TC_REPORT_SENDER=<a sender verified in Brevo>  (must be an authenticated sender/domain)
TC_SMTP_HOST=
TC_SMTP_PORT=587
TC_SMTP_USER=
TC_SMTP_PASSWORD=
TC_SMTP_STARTTLS=true
# Telegram (if TC_REPORT_CHANNEL=telegram):
TC_TELEGRAM_BOT_TOKEN=
TC_TELEGRAM_CHAT_ID=
