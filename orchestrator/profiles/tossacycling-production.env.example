# Site profile: PRODUCTION — copy to production.env and fill in.
# Select with: TC_SITE=production  or  python -m tc_growth.cli --site production <command>
#
# PRODUCTION IS READ-ONLY BY CONSTRUCTION: TC_ALLOW_WRITES=false is enforced in code beneath
# the phase gate (core/approval.is_tool_allowed) — no command, phase request, or prompt can
# produce a write against this profile. Flipping this to true is a Phase-4 gate decision
# (see docs/ROADMAP.md), not a config tweak.

# --- Site identity ---
TC_SITE_NAME=Tossa Cycling
TC_ENV_KIND=production
TC_ALLOW_WRITES=false

# --- WordPress connector (requires the connector plugin installed on production) ---
TC_WP_BASE_URL=https://www.tossacycling.com
TC_WP_USER=tc-agent
TC_WP_APP_PASSWORD=           # SEPARATE application password from staging
TC_WP_SIGNING_KEY=            # SEPARATE signing key from staging — never reuse

# --- Google ---
TC_GSC_SITE_URL=sc-domain:tossacycling.com
TC_GA4_PROPERTY_ID=

# --- AI runtime ---
TC_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# --- Reporting ---
TC_REPORT_CHANNEL=email
TC_REPORT_RECIPIENT=lukaszkomar@gmail.com

# --- Persistence: leave blank -> data/tc_growth-production.db.
# NOTE: for Tossa Cycling, staging and production are the SAME business — when Phase 4 begins,
# decide deliberately whether production runs share the staging store (one business memory) by
# setting TC_DB_PATH to the same file, or keep separate stores. Default is separate (safe).
TC_DB_PATH=
