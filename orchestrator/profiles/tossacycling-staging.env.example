# Site profile: STAGING — copy to staging.env and fill in. Profiles are COMPLETE per site:
# separate credentials, signing key, and store — never shared with another profile.
# Select with: TC_SITE=staging  or  python -m tc_growth.cli --site staging <command>

# --- Site identity ---
TC_SITE_NAME=Tossa Cycling
TC_ENV_KIND=staging
TC_ALLOW_WRITES=true          # staging may create drafts (still gated by phase + approvals)

# --- WordPress connector ---
TC_WP_BASE_URL=https://dev.tourdegirona.com
TC_WP_USER=tc-agent
TC_WP_APP_PASSWORD=
TC_WP_SIGNING_KEY=            # UNIQUE to this site — never reuse across profiles

# --- Google (production data may still be read from staging profile if desired) ---
TC_GSC_SITE_URL=sc-domain:tossacycling.com
TC_GA4_PROPERTY_ID=

# --- AI runtime ---
TC_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# --- Reporting / SMTP: copy the block from .env.example ---
TC_REPORT_CHANNEL=email
TC_REPORT_RECIPIENT=lukaszkomar@gmail.com

# --- Persistence: leave blank -> data/tc_growth-staging.db (own store per site) ---
TC_DB_PATH=
